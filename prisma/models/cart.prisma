model Cart {
    id           String     @id @default(uuid())
    userId       String     @unique
    restaurantId String
    totalAmount  Decimal    @default(0) @db.Decimal(10, 2)
    cartItems    CartItem[]
    createdAt    DateTime   @default(now()) @db.Timestamp()
    updatedAt    DateTime   @updatedAt
    user         User       @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onUpdate: Cascade, onDelete: Cascade)

    @@index([restaurantId])
}

model CartItem {
    id         String          @id @default(uuid())
    cartId     String
    foodItemId String
    variantId  String?
    quantity   Int             @default(1)
    unitPrice  Decimal         @db.Decimal(10, 2)
    addOnIds   CartItemAddOn[]
    createdAt  DateTime        @default(now()) @db.Timestamp()
    updatedAt  DateTime        @updatedAt
    cart       Cart            @relation(fields: [cartId], references: [id], onUpdate: Cascade, onDelete: Cascade)
    foodItem   FoodItem        @relation(fields: [foodItemId], references: [id], onUpdate: Cascade, onDelete: Cascade)
    variant    FoodVariant?    @relation(fields: [variantId], references: [id], onUpdate: Cascade, onDelete: SetNull)

    @@unique([cartId, foodItemId, variantId])
    @@index([cartId])
    @@index([foodItemId])
}

model CartItemAddOn {
    id         String   @id @default(uuid())
    cartItemId String
    addOnId    String
    quantity   Int      @default(1)
    unitPrice  Decimal  @db.Decimal(10, 2)
    createdAt  DateTime @default(now()) @db.Timestamp()
    updatedAt  DateTime @updatedAt
    cartItem   CartItem @relation(fields: [cartItemId], references: [id], onUpdate: Cascade, onDelete: Cascade)
    addOn      AddOn    @relation(fields: [addOnId], references: [id], onUpdate: Cascade, onDelete: Cascade)

    @@unique([cartItemId, addOnId])
    @@index([cartItemId])
}
