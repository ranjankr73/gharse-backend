model Rider {
    id                  String               @id @default(uuid())
    userId              String               @unique
    vehicleType         VehicleType
    vehicleNumber       String               @db.VarChar(20)
    licenseNumber       String               @unique @db.VarChar(50)
    isAvailable         Boolean              @default(false)
    isVerified          Boolean              @default(false)
    isActive            Boolean              @default(true)
    currentLatitude     Decimal?             @db.Decimal(10, 8)
    currentLongitude    Decimal?             @db.Decimal(11, 8)
    lastLocationAt      DateTime?            @db.Timestamp()
    totalDeliveries     Int                  @default(0)
    avgRating           Decimal?             @db.Decimal(3, 2)
    totalRatings        Int                  @default(0)
    deliveryAssignments DeliveryAssignment[]
    reviews             Review[]
    orders              Order[]
    createdAt           DateTime             @default(now()) @db.Timestamp()
    updatedAt           DateTime             @updatedAt
    user                User                 @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

    @@index([isAvailable, isActive])
    @@index([currentLatitude, currentLongitude])
    @@index([vehicleType])
}

model DeliveryAssignment {
    id                 String         @id @default(uuid())
    orderId            String         
    riderId            String
    status             DeliveryStatus @default(ASSIGNED)
    assignedAt         DateTime       @default(now()) @db.Timestamp()
    acceptedAt         DateTime?      @db.Timestamp()
    pickedUpAt         DateTime?      @db.Timestamp()
    deliveredAt        DateTime?      @db.Timestamp()
    cancelledAt        DateTime?      @db.Timestamp()
    cancellationReason String?        @db.Text
    distanceKm         Decimal?       @db.Decimal(6, 2)
    createdAt          DateTime       @default(now()) @db.Timestamp()
    updatedAt          DateTime       @updatedAt
    order              Order          @relation(fields: [orderId], references: [id], onUpdate: Cascade, onDelete: Restrict)
    rider              Rider          @relation(fields: [riderId], references: [id], onUpdate: Cascade, onDelete: Restrict)

    @@index([riderId])
    @@index([status])
    @@index([riderId, status])
    @@index([assignedAt])
}

enum VehicleType {
    BICYCLE
    BIKE
    SCOOTER
    CAR
    VAN
}

enum DeliveryStatus {
    ASSIGNED
    ACCEPTED
    PICKED_UP
    DELIVERED
    CANCELLED
}
